generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  OPERATOR
}

enum EventType {
  COURSE
  THEATER
}

enum EventModality {
  IN_PERSON
  ONLINE
  HYBRID
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum OccurrenceStatus {
  SCHEDULED
  CANCELLED
  SOLD_OUT
}

enum ReservationStatus {
  PENDING_PAYMENT
  PAYMENT_REVIEW
  CONFIRMED
  REJECTED
  EXPIRED
  CANCELLED
}

enum PaymentMethodKind {
  BS
  USDT
}

enum UploadKind {
  EVENT_IMAGE
  RECEIPT
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Event {
  id                  String        @id @default(cuid())
  slug                String        @unique
  title               String
  summary             String
  description         String
  type                EventType
  modality            EventModality
  status              EventStatus   @default(DRAFT)
  location            String?
  imagePath           String?
  reservationTtlMin   Int
  featured            Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  occurrences         EventOccurrence[]
  priceVariants       PriceVariant[]
  reservations        Reservation[]

  @@index([status])
  @@index([type])
}

model EventOccurrence {
  id        String            @id @default(cuid())
  eventId   String
  startsAt  DateTime
  endsAt    DateTime?
  capacity  Int
  status    OccurrenceStatus  @default(SCHEDULED)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  event        Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  reservationItems ReservationItem[]

  @@index([eventId])
}

model PriceVariant {
  id          String   @id @default(cuid())
  eventId     String
  name        String
  priceUsd    Decimal  @db.Decimal(10, 2)
  capacity    Int?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  reservationItems ReservationItem[]

  @@index([eventId])
}

model Reservation {
  id                String             @id @default(cuid())
  code              String             @unique
  eventId           String
  buyerFirstName    String
  buyerLastName     String
  buyerWhatsapp     String
  buyerNote         String?
  status            ReservationStatus  @default(PENDING_PAYMENT)
  paymentMethodKind PaymentMethodKind
  exchangeRate      Decimal?           @db.Decimal(18, 4)
  amountUsd         Decimal            @db.Decimal(12, 2)
  amountBs          Decimal?           @db.Decimal(18, 2)
  expiresAt         DateTime
  receiptPath       String?
  internalNote      String?
  confirmedAt       DateTime?
  rejectedAt        DateTime?
  cancelledAt       DateTime?
  checkInsCount     Int                @default(0)
  firstCheckInAt    DateTime?
  lastCheckInAt     DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  event             Event              @relation(fields: [eventId], references: [id])
  items             ReservationItem[]

  @@index([eventId])
  @@index([status])
  @@index([buyerWhatsapp])
}

model ReservationItem {
  id             String   @id @default(cuid())
  reservationId  String
  occurrenceId   String
  priceVariantId String
  quantity       Int
  unitPriceUsd   Decimal  @db.Decimal(10, 2)

  reservation    Reservation     @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  occurrence     EventOccurrence @relation(fields: [occurrenceId], references: [id])
  priceVariant   PriceVariant    @relation(fields: [priceVariantId], references: [id])

  @@index([reservationId])
  @@index([occurrenceId])
}

model PaymentMethod {
  id           String            @id @default(cuid())
  kind         PaymentMethodKind @unique
  label        String
  instructions String
  active       Boolean           @default(true)
  updatedAt    DateTime          @updatedAt
}

model ExchangeRate {
  id        String   @id @default(cuid())
  bsPerUsd  Decimal  @db.Decimal(18, 4)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([active, createdAt])
}

model UploadedFile {
  id           String     @id @default(cuid())
  kind         UploadKind
  path         String
  originalName String
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime   @default(now())
}

model ReservationCounter {
  id    Int @id @default(1)
  value Int @default(0)
}
